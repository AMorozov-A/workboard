# Зависимости (в каждом пакете свой node_modules)
node_modules/
**/node_modules/

# Сборка
dist/
**/dist/
build/
**/build/

# Локальные секреты (шаблоны .env.example остаются в git)
.env
.env.local
.env.*.local

# Vite / Vitest cache
.vite/
.vitest-cache/
**/.vitest-cache/

# E2E: временные SQLite и прочие артефакты пакета
e2e/temp/

# Покрытие и отчёты тестов
coverage/
**/coverage/
.nyc_output/

# Playwright (корень и пакет e2e/)
playwright-report/
test-results/
blob-report/
e2e/test-results/
e2e/playwright-report/

# SQLite — дев-файлы БД (см. также backend/.gitignore)
*.db
*.db-journal
*.db-wal
*.db-shm

# IDE / ОС
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Cursor IDE (локальные правила и настройки)
.cursor/

# Логи
*.log
npm-debug.log*
pnpm-debug.log*
