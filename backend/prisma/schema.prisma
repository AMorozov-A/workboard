// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  active
  paused
  done
}

enum ProjectPriority {
  low
  medium
  high
  critical
}

enum ProjectHealth {
  on_track
  at_risk
  off_track
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  comments     Comment[]
  tags         Tag[]
}

model Project {
  id          String         @id @default(uuid())
  key         String
  taskKeyPrefix String        @default("T")
  title       String
  description String?
  client      String?
  status      ProjectStatus  @default(active)
  priority    ProjectPriority @default(medium)
  health      ProjectHealth   @default(on_track)
  budget      Float?
  deadline    DateTime?
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  tags        Tag[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, key])
}

model Task {
  id          String           @id @default(uuid())
  key         String
  title       String
  description String?
  status      TaskStatus       @default(todo)
  priority    TaskPriority     @default(medium)
  dueDate     DateTime?
  labels      Json?
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    Comment[]
  notes       TaskNote[]
  checklist   ChecklistItem[]
  tags        Tag[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([projectId, key])
}

model ChecklistItem {
  id        String   @id @default(uuid())
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model Comment {
  id        String   @id @default(uuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TaskNote {
  id        String   @id @default(uuid())
  key       String
  title     String?
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, key])
  @@index([taskId])
}
